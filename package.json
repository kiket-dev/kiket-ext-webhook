{
  "name": "@kiket/ext-webhook",
  "version": "1.0.0",
  "private": true,
  "description": "Generic webhook evidence adapter for Kiket platform ingestion",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./adapter": {
      "import": "./dist/adapter.js",
      "types": "./dist/adapter.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check --diagnostic-level=error src/"
  },
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.19.19",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
